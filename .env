APP_ENV=dev
APP_SECRET=change-me-please

APP_SHARE_DIR=var/share

SERVER_NAME=localhost

HTTP_PORT=8071
HTTPS_PORT=443
HTTP3_PORT=443

POSTGRES_PORT=5471

DEFAULT_URI=https://localhost

POSTGRES_VERSION=16
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

DATABASE_URL="postgresql://app:app@postgres:5432/app?serverVersion=16&charset=utf8"

MERCURE_URL=http://php/.well-known/mercure
MERCURE_PUBLIC_URL=https://localhost/.well-known/mercure
MERCURE_JWT_SECRET=ChangeThisMercureHubJWTSecretKey
CADDY_MERCURE_JWT_SECRET=ChangeThisMercureHubJWTSecretKey

RABBITMQ_USER=app
RABBITMQ_PASSWORD=app

MESSENGER_TRANSPORT_DSN=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/%2f

MAILER_DSN=null://null
