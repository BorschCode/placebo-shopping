{% extends 'base.html.twig' %}
{% block title %}{{ 'title.my_profile'|trans }}{% endblock %}

{% block body %}
<nav class="breadcrumbs">
    <a href="{{ path('app_home') }}">← {{ 'common.home'|trans }}</a>
    <span>{{ 'profile.title'|trans }}</span>
</nav>
<div class="profile-page">
    <div class="profile-card">
        {% if user.profile and user.profile.avatarPath %}
            <img src="{{ user.profile.avatarPath }}" alt="{{ 'profile.avatar'|trans }}" class="profile-avatar">
        {% else %}
            <div class="profile-avatar-placeholder">{{ (user.profile.displayName ?? user.email)|slice(0,1)|upper }}</div>
        {% endif %}
        <h2>{{ user.profile ? user.profile.displayNameOrEmail : user.email }}</h2>
        {% if user.profile and user.profile.location %}
            <p class="profile-location">📍 {{ user.profile.location }}</p>
        {% endif %}
        {% if user.profile and user.profile.bio %}
            <p class="profile-bio">{{ user.profile.bio }}</p>
        {% endif %}
        {% if user.profile and user.profile.phone %}
            <p class="profile-phone">📞 {{ user.profile.phone }}</p>
        {% endif %}
        <p class="profile-theme">{{ 'profile.theme_label'|trans }}: <strong>{{ user.theme.label() }}</strong></p>
        <a href="{{ path('app_profile_edit') }}" class="btn btn-primary">{{ 'profile.edit_btn'|trans }}</a>
        <div style="margin-top:16px">{% include '_locale_switcher.html.twig' %}</div>
    </div>
</div>
{% endblock %}
