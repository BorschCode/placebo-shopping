{% extends 'themes/olx/layout.html.twig' %}
{% block title %}OLX — Безкоштовні оголошення{% endblock %}

{% block theme_content %}
    <h2 class="section-title">Популярні категорії</h2>
    <div class="category-bar">
        {% for cat in categories %}
            <a href="{{ path('app_listings', {category: cat.slug}) }}" class="category-chip">{{ cat.icon }} {{ cat.name }}</a>
        {% endfor %}
    </div>

    <h2 class="section-title">Свіжі оголошення</h2>
    <div class="listing-grid">
        {% for listing in listings %}
            {% include 'listing/_card.html.twig' %}
        {% else %}
            <p style="color:#888">Оголошень поки немає. <a href="#">Додати перше?</a></p>
        {% endfor %}
    </div>
{% endblock %}
