{# OLX theme — classifieds, sidebar chat #}
{% extends 'base.html.twig' %}

{% block body %}
<div class="theme-olx">
    <nav class="navbar">
        <a href="{{ path('app_home') }}" class="navbar-brand">🛍️ OLX</a>
        <nav class="navbar-nav">
            <a href="{{ path('app_listings') }}">Оголошення</a>
            <a href="{{ path('app_chats') }}">💬 Повідомлення</a>
            <a href="{{ path('app_profile') }}">{{ app.user.profile ? app.user.profile.displayNameOrEmail : app.user.email }}</a>
            <a href="{{ path('app_logout') }}">Вийти</a>
        </nav>
    </nav>

    <div class="page-content">
        {% block theme_content %}{% endblock %}
    </div>

    {% block chat_widget %}{% endblock %}
</div>
{% endblock %}
