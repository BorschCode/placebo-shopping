{% extends 'themes/olx/layout.html.twig' %}
{% block title %}Оголошення — OLX{% endblock %}

{% block theme_content %}
    <div class="category-bar">
        <a href="{{ path('app_listings') }}" class="category-chip {{ activeCategory is null ? 'active' : '' }}">Всі</a>
        {% for cat in categories %}
            <a href="{{ path('app_listings', {category: cat.slug}) }}"
               class="category-chip {{ activeCategory and activeCategory.id == cat.id ? 'active' : '' }}">
                {{ cat.icon }} {{ cat.name }}
            </a>
        {% endfor %}
    </div>

    <div class="listing-grid">
        {% for listing in listings %}
            {% include 'listing/_card.html.twig' %}
        {% else %}
            <p style="color:#888;grid-column:1/-1">Оголошень не знайдено.</p>
        {% endfor %}
    </div>
{% endblock %}
