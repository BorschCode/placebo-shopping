{% extends 'themes/experinza/layout.html.twig' %}
{% block title %}Experinza — Замов їжу онлайн{% endblock %}

{% block theme_content %}
    <div style="background:linear-gradient(135deg,#16a34a,#15803d);color:#fff;border-radius:20px;padding:32px;margin-bottom:28px">
        <h1 style="font-size:28px;font-weight:800;margin-bottom:8px">🍕 Голодний?</h1>
        <p style="opacity:.9">Замов улюблену їжу за 30 хвилин</p>
    </div>

    <div class="category-bar">
        {% for cat in categories %}
            <a href="{{ path('app_listings', {category: cat.slug}) }}" class="category-chip">{{ cat.icon }} {{ cat.name }}</a>
        {% endfor %}
    </div>

    <h2 class="section-title">Популярне сьогодні</h2>
    <div class="listing-grid">
        {% for listing in listings %}
            {% include 'listing/_card.html.twig' %}
        {% else %}
            <p style="color:#888">Страв поки немає.</p>
        {% endfor %}
    </div>
{% endblock %}
