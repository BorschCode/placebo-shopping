{% extends 'themes/autoria/layout.html.twig' %}
{% block title %}{{ 'title.autoria_home'|trans }}{% endblock %}

{% block theme_content %}
    <div style="background:var(--accent);color:#fff;border-radius:16px;padding:32px;margin-bottom:28px">
        <h1 style="font-size:28px;font-weight:800;margin-bottom:8px">{{ 'autoria.home.headline'|trans }}</h1>
        <p style="opacity:.85">{{ 'autoria.home.subheadline'|trans }}</p>
    </div>

    <div class="category-bar">
        {% for cat in categories %}
            <a href="{{ path('app_listings', {category: cat.slug}) }}" class="category-chip">{{ cat.icon }} {{ cat.name }}</a>
        {% endfor %}
    </div>

    <h2 class="section-title">{{ 'autoria.home.new_listings'|trans }}</h2>
    <div class="listing-grid">
        {% for listing in listings %}
            {% include 'listing/_card.html.twig' %}
        {% else %}
            <p style="color:#888">{{ 'home.no_listings'|trans }}</p>
        {% endfor %}
    </div>
{% endblock %}
