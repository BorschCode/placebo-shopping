{% extends 'base.html.twig' %}
{% block title %}{{ 'title.register'|trans }}{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">🛍️</div>
        <h1 class="auth-title">{{ 'auth.register_title'|trans }}</h1>

        {{ form_start(form, {'attr': {'class': 'auth-form'}}) }}
            <div class="form-group">
                {{ form_label(form.email, 'Email') }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>
            <div class="form-group">
                {{ form_label(form.plainPassword, 'auth.password'|trans) }}
                {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.plainPassword) }}
            </div>
            <div class="form-check">
                {{ form_widget(form.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.agreeTerms) }}
                {{ form_errors(form.agreeTerms) }}
            </div>
            <button type="submit" class="btn btn-primary btn-block">{{ 'auth.register_btn'|trans }}</button>
        {{ form_end(form) }}

        <p class="auth-alt">{{ 'auth.has_account'|trans }} <a href="{{ path('app_login') }}">{{ 'auth.login_link'|trans }}</a></p>
        <div style="margin-top:16px;display:flex;justify-content:center">{% include '_locale_switcher.html.twig' %}</div>
    </div>
</div>
{% endblock %}
