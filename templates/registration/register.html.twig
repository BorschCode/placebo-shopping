{% extends 'base.html.twig' %}
{% block title %}Реєстрація — Placebo Shopping{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">🛍️</div>
        <h1 class="auth-title">Реєстрація</h1>

        {{ form_start(form, {'attr': {'class': 'auth-form'}}) }}
            <div class="form-group">
                {{ form_label(form.email, 'Email') }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>
            <div class="form-group">
                {{ form_label(form.plainPassword, 'Пароль') }}
                {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.plainPassword) }}
            </div>
            <div class="form-check">
                {{ form_widget(form.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.agreeTerms) }}
                {{ form_errors(form.agreeTerms) }}
            </div>
            <button type="submit" class="btn btn-primary btn-block">Зареєструватись</button>
        {{ form_end(form) }}

        <p class="auth-alt">Вже є акаунт? <a href="{{ path('app_login') }}">Увійти</a></p>
    </div>
</div>
{% endblock %}
