{% extends 'base.html.twig' %}
{% block title %}{{ 'title.login'|trans }}{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">🛍️</div>
        <h1 class="auth-title">{{ 'auth.login_title'|trans }}</h1>

        {% if error %}
            <div class="flash flash--error"><p>{{ error.messageKey|trans(error.messageData, 'security') }}</p></div>
        {% endif %}

        <form method="post" class="auth-form">
            <div class="form-group">
                <label for="inputEmail">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
            </div>
            <div class="form-group">
                <label for="inputPassword">{{ 'auth.password'|trans }}</label>
                <input type="password" name="_password" id="inputPassword" class="form-control" autocomplete="current-password" required>
            </div>
            <div class="form-check">
                <input type="checkbox" name="_remember_me" id="rememberMe" class="form-check-input">
                <label for="rememberMe">{{ 'auth.remember_me'|trans }}</label>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-primary btn-block">{{ 'auth.login_btn'|trans }}</button>
        </form>

        <p class="auth-alt">{{ 'auth.no_account'|trans }} <a href="{{ path('app_register') }}">{{ 'auth.register_link'|trans }}</a></p>
        <div style="margin-top:16px;display:flex;justify-content:center">{% include '_locale_switcher.html.twig' %}</div>
    </div>
</div>
{% endblock %}
